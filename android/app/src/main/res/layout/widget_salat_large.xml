<?xml version="1.0" encoding="utf-8"?>
<!-- 4x2 breakpoint: left block (icon, countdown, next prayer) + right forecast-style
     list of upcoming prayers and their leave times, mirroring a weather widget's
     "current + next few days" layout. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom">

        <ImageView
            android:id="@+id/widget_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_notification"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/tajawal_bold"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_prayer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/tajawal_regular"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="" />

        <TextView
            android:id="@+id/widget_leave_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/tajawal_bold"
            android:textColor="#E8B84B"
            android:textSize="12sp"
            android:text="" />
    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="14dp"
        android:background="@drawable/widget_divider" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/widget_row1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp">
            <TextView
                android:id="@+id/widget_row1_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/tajawal_regular"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
            <TextView
                android:id="@+id/widget_row1_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/tajawal_bold"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/widget_divider" />

        <LinearLayout
            android:id="@+id/widget_row2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp">
            <TextView
                android:id="@+id/widget_row2_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/tajawal_regular"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
            <TextView
                android:id="@+id/widget_row2_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/tajawal_bold"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/widget_divider" />

        <LinearLayout
            android:id="@+id/widget_row3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp">
            <TextView
                android:id="@+id/widget_row3_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/tajawal_regular"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
            <TextView
                android:id="@+id/widget_row3_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/tajawal_bold"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/widget_divider" />

        <LinearLayout
            android:id="@+id/widget_row4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp">
            <TextView
                android:id="@+id/widget_row4_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/tajawal_regular"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="" />
            <TextView
                android:id="@+id/widget_row4_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/tajawal_bold"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
